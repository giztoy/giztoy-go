{
  "openapi": "3.0.3",
  "info": {
    "title": "Server Public API",
    "description": "Public server endpoints.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "tags": [
    {
      "name": "Public",
      "description": "Public gear operations"
    }
  ],
  "paths": {
    "/server-info": {
      "get": {
        "operationId": "getServerInfo",
        "summary": "Get server information",
        "tags": [
          "Public"
        ],
        "responses": {
          "200": {
            "description": "Server info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./types.json#/components/schemas/ServerInfo"
                }
              }
            }
          },
          "400": {
            "description": "Invalid params",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./types.json#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/register": {
      "post": {
        "operationId": "registerGear",
        "summary": "Register a gear",
        "tags": [
          "Public"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegistrationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Registration result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegistrationResult"
                }
              }
            }
          },
          "400": {
            "description": "Invalid params",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./types.json#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Gear already exists",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./types.json#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "RegistrationRequest": {
        "type": "object",
        "required": [
          "public_key",
          "device"
        ],
        "properties": {
          "public_key": {
            "type": "string"
          },
          "device": {
            "$ref": "./types.json#/components/schemas/DeviceInfo"
          },
          "registration_token": {
            "type": "string"
          }
        }
      },
      "RegistrationResult": {
        "type": "object",
        "required": [
          "gear",
          "registration"
        ],
        "properties": {
          "gear": {
            "$ref": "./types.json#/components/schemas/Gear"
          },
          "registration": {
            "$ref": "./types.json#/components/schemas/Registration"
          }
        }
      }
    }
  }
}
