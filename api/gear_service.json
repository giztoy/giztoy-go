{
  "openapi": "3.0.3",
  "info": {
    "title": "Gears Admin API",
    "description": "Admin endpoints for managing gears (devices).",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "tags": [
    {
      "name": "Query",
      "description": "List and resolve gears"
    },
    {
      "name": "Resource",
      "description": "Single gear CRUD and actions"
    }
  ],
  "paths": {
    "/gears": {
      "get": {
        "operationId": "listGears",
        "summary": "List all gears",
        "tags": [
          "Query"
        ],
        "responses": {
          "200": {
            "description": "Gear registration list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegistrationList"
                }
              }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/gears/sn/{sn}": {
      "get": {
        "operationId": "resolveBySN",
        "summary": "Resolve gear public key by serial number",
        "tags": [
          "Query"
        ],
        "parameters": [
          {
            "name": "sn",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Resolved public key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicKeyResponse"
                }
              }
            }
          },
          "404": {
            "description": "Gear not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/gears/imei/{tac}/{serial}": {
      "get": {
        "operationId": "resolveByIMEI",
        "summary": "Resolve gear public key by IMEI",
        "tags": [
          "Query"
        ],
        "parameters": [
          {
            "name": "tac",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "serial",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Resolved public key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicKeyResponse"
                }
              }
            }
          },
          "404": {
            "description": "Gear not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/gears/label/{key}/{value}": {
      "get": {
        "operationId": "listByLabel",
        "summary": "List gears by label",
        "tags": [
          "Query"
        ],
        "parameters": [
          {
            "name": "key",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "value",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Matched gears",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegistrationList"
                }
              }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/gears/certification/{type}/{authority}/{id}": {
      "get": {
        "operationId": "listByCertification",
        "summary": "List gears by certification",
        "tags": [
          "Query"
        ],
        "parameters": [
          {
            "name": "type",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/GearCertificationType"
            }
          },
          {
            "name": "authority",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/GearCertificationAuthority"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Matched gears",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegistrationList"
                }
              }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/gears/firmware/{depot}/{channel}": {
      "get": {
        "operationId": "listByFirmware",
        "summary": "List gears by firmware depot and channel",
        "tags": [
          "Query"
        ],
        "parameters": [
          {
            "name": "depot",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "channel",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/GearFirmwareChannel"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Matched gears",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegistrationList"
                }
              }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/gears/{publicKey}": {
      "get": {
        "operationId": "getGear",
        "summary": "Get gear registration",
        "tags": [
          "Resource"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/publicKey"
          }
        ],
        "responses": {
          "200": {
            "description": "Gear registration",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Registration"
                }
              }
            }
          },
          "404": {
            "description": "Gear not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteGear",
        "summary": "Delete a gear",
        "tags": [
          "Resource"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/publicKey"
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted gear registration",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Registration"
                }
              }
            }
          },
          "404": {
            "description": "Gear not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/gears/{publicKey}:approve": {
      "post": {
        "operationId": "approveGear",
        "summary": "Approve a gear with a given role",
        "tags": [
          "Resource"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/publicKey"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ApproveRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Approved gear registration",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Registration"
                }
              }
            }
          },
          "400": {
            "description": "Invalid role",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/gears/{publicKey}:block": {
      "post": {
        "operationId": "blockGear",
        "summary": "Block a gear",
        "tags": [
          "Resource"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/publicKey"
          }
        ],
        "responses": {
          "200": {
            "description": "Blocked gear registration",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Registration"
                }
              }
            }
          },
          "404": {
            "description": "Gear not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/gears/{publicKey}:refresh": {
      "post": {
        "operationId": "refreshGear",
        "summary": "Refresh gear info from connected device",
        "tags": [
          "Resource"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/publicKey"
          }
        ],
        "responses": {
          "200": {
            "description": "Refresh result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RefreshResult"
                }
              }
            }
          },
          "404": {
            "description": "Gear not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Device offline",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "502": {
            "description": "Device refresh failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/gears/{publicKey}/info": {
      "get": {
        "operationId": "getGearInfo",
        "summary": "Get gear device info",
        "tags": [
          "Resource"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/publicKey"
          }
        ],
        "responses": {
          "200": {
            "description": "Device info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeviceInfo"
                }
              }
            }
          },
          "404": {
            "description": "Gear not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/gears/{publicKey}/config": {
      "get": {
        "operationId": "getGearConfig",
        "summary": "Get gear configuration",
        "tags": [
          "Resource"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/publicKey"
          }
        ],
        "responses": {
          "200": {
            "description": "Configuration",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Configuration"
                }
              }
            }
          },
          "404": {
            "description": "Gear not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "putGearConfig",
        "summary": "Update gear configuration",
        "tags": [
          "Resource"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/publicKey"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Configuration"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated configuration",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Configuration"
                }
              }
            }
          },
          "400": {
            "description": "Invalid params",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Gear not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/gears/{publicKey}/runtime": {
      "get": {
        "operationId": "getGearRuntime",
        "summary": "Get gear runtime status",
        "tags": [
          "Resource"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/publicKey"
          }
        ],
        "responses": {
          "200": {
            "description": "Runtime status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Runtime"
                }
              }
            }
          }
        }
      }
    },
    "/gears/{publicKey}/ota": {
      "get": {
        "operationId": "getGearOTA",
        "summary": "Get gear OTA firmware summary",
        "tags": [
          "Resource"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/publicKey"
          }
        ],
        "responses": {
          "200": {
            "description": "OTA summary",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OTASummary"
                }
              }
            }
          },
          "404": {
            "description": "Gear or firmware not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "publicKey": {
        "name": "publicKey",
        "in": "path",
        "required": true,
        "description": "Gear public key",
        "schema": {
          "type": "string"
        }
      }
    },
    "schemas": {
      "Channel": {
        "type": "string",
        "enum": [
          "rollback",
          "stable",
          "beta",
          "testing"
        ]
      },
      "Depot": {
        "type": "object",
        "required": [
          "name",
          "info",
          "rollback",
          "stable",
          "beta",
          "testing"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "info": {
            "$ref": "#/components/schemas/DepotInfo"
          },
          "rollback": {
            "$ref": "#/components/schemas/DepotRelease"
          },
          "stable": {
            "$ref": "#/components/schemas/DepotRelease"
          },
          "beta": {
            "$ref": "#/components/schemas/DepotRelease"
          },
          "testing": {
            "$ref": "#/components/schemas/DepotRelease"
          }
        }
      },
      "DepotList": {
        "type": "object",
        "required": [
          "items"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Depot"
            }
          }
        }
      },
      "DepotInfo": {
        "type": "object",
        "properties": {
          "files": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DepotInfoFile"
            }
          }
        }
      },
      "DepotInfoFile": {
        "type": "object",
        "required": [
          "path"
        ],
        "properties": {
          "path": {
            "type": "string"
          }
        }
      },
      "DepotRelease": {
        "type": "object",
        "required": [
          "firmware_semver"
        ],
        "properties": {
          "firmware_semver": {
            "type": "string"
          },
          "channel": {
            "type": "string"
          },
          "files": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DepotFile"
            }
          }
        }
      },
      "DepotFile": {
        "type": "object",
        "required": [
          "path",
          "sha256",
          "md5"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": "string"
          },
          "md5": {
            "type": "string"
          }
        }
      },
      "GearRole": {
        "type": "string",
        "enum": [
          "unspecified",
          "admin",
          "peer",
          "device"
        ]
      },
      "GearStatus": {
        "type": "string",
        "enum": [
          "unspecified",
          "active",
          "blocked"
        ]
      },
      "GearFirmwareChannel": {
        "type": "string",
        "enum": [
          "rollback",
          "stable",
          "beta",
          "testing"
        ]
      },
      "GearCertificationType": {
        "type": "string",
        "enum": [
          "license",
          "certification"
        ]
      },
      "GearCertificationAuthority": {
        "type": "string",
        "enum": [
          "unknown",
          "ccc",
          "ce",
          "fcc",
          "miit",
          "srrc",
          "rohs",
          "internal"
        ]
      },
      "GearIMEI": {
        "type": "object",
        "required": [
          "tac",
          "serial"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "tac": {
            "type": "string"
          },
          "serial": {
            "type": "string"
          }
        }
      },
      "GearLabel": {
        "type": "object",
        "required": [
          "key",
          "value"
        ],
        "properties": {
          "key": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        }
      },
      "GearCertification": {
        "type": "object",
        "required": [
          "type",
          "authority",
          "id"
        ],
        "properties": {
          "type": {
            "$ref": "#/components/schemas/GearCertificationType"
          },
          "authority": {
            "$ref": "#/components/schemas/GearCertificationAuthority"
          },
          "id": {
            "type": "string"
          },
          "authority_name": {
            "type": "string"
          }
        }
      },
      "HardwareInfo": {
        "type": "object",
        "properties": {
          "manufacturer": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "hardware_revision": {
            "type": "string"
          },
          "depot": {
            "type": "string"
          },
          "firmware_semver": {
            "type": "string"
          },
          "imeis": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GearIMEI"
            }
          },
          "labels": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GearLabel"
            }
          }
        }
      },
      "DeviceInfo": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "sn": {
            "type": "string"
          },
          "hardware": {
            "$ref": "#/components/schemas/HardwareInfo"
          }
        }
      },
      "FirmwareConfig": {
        "type": "object",
        "properties": {
          "channel": {
            "$ref": "#/components/schemas/GearFirmwareChannel"
          }
        }
      },
      "Configuration": {
        "type": "object",
        "properties": {
          "certifications": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GearCertification"
            }
          },
          "firmware": {
            "$ref": "#/components/schemas/FirmwareConfig"
          }
        }
      },
      "Registration": {
        "type": "object",
        "required": [
          "public_key",
          "role",
          "status",
          "created_at",
          "updated_at"
        ],
        "properties": {
          "public_key": {
            "type": "string"
          },
          "role": {
            "$ref": "#/components/schemas/GearRole"
          },
          "status": {
            "$ref": "#/components/schemas/GearStatus"
          },
          "auto_registered": {
            "type": "boolean"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "approved_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "RegistrationList": {
        "type": "object",
        "required": [
          "items"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Registration"
            }
          }
        }
      },
      "Runtime": {
        "type": "object",
        "required": [
          "online",
          "last_seen_at"
        ],
        "properties": {
          "online": {
            "type": "boolean"
          },
          "last_seen_at": {
            "type": "string",
            "format": "date-time"
          },
          "last_addr": {
            "type": "string"
          }
        }
      },
      "RefreshResult": {
        "type": "object",
        "required": [
          "gear"
        ],
        "properties": {
          "gear": {
            "$ref": "#/components/schemas/Gear"
          },
          "updated_fields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "Gear": {
        "type": "object",
        "required": [
          "public_key",
          "role",
          "status",
          "device",
          "configuration",
          "created_at",
          "updated_at"
        ],
        "properties": {
          "public_key": {
            "type": "string"
          },
          "role": {
            "$ref": "#/components/schemas/GearRole"
          },
          "status": {
            "$ref": "#/components/schemas/GearStatus"
          },
          "device": {
            "$ref": "#/components/schemas/DeviceInfo"
          },
          "configuration": {
            "$ref": "#/components/schemas/Configuration"
          },
          "auto_registered": {
            "type": "boolean"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
