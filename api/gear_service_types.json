{
  "openapi": "3.0.3",
  "info": {
    "title": "Gear Types",
    "description": "Schemas used by the gear admin API.",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "parameters": {
      "publicKey": {
        "name": "publicKey",
        "in": "path",
        "required": true,
        "description": "Gear public key",
        "schema": {
          "type": "string"
        }
      }
    },
    "schemas": {
      "Channel": {
        "type": "string",
        "enum": [
          "rollback",
          "stable",
          "beta",
          "testing"
        ]
      },
      "Depot": {
        "type": "object",
        "required": [
          "name",
          "info",
          "rollback",
          "stable",
          "beta",
          "testing"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "info": {
            "$ref": "#/components/schemas/DepotInfo"
          },
          "rollback": {
            "$ref": "#/components/schemas/DepotRelease"
          },
          "stable": {
            "$ref": "#/components/schemas/DepotRelease"
          },
          "beta": {
            "$ref": "#/components/schemas/DepotRelease"
          },
          "testing": {
            "$ref": "#/components/schemas/DepotRelease"
          }
        }
      },
      "DepotList": {
        "type": "object",
        "required": [
          "items"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Depot"
            }
          }
        }
      },
      "DepotInfo": {
        "type": "object",
        "properties": {
          "files": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DepotInfoFile"
            }
          }
        }
      },
      "DepotInfoFile": {
        "type": "object",
        "required": [
          "path"
        ],
        "properties": {
          "path": {
            "type": "string"
          }
        }
      },
      "DepotRelease": {
        "type": "object",
        "required": [
          "firmware_semver"
        ],
        "properties": {
          "firmware_semver": {
            "type": "string"
          },
          "channel": {
            "type": "string"
          },
          "files": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DepotFile"
            }
          }
        }
      },
      "DepotFile": {
        "type": "object",
        "required": [
          "path",
          "sha256",
          "md5"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": "string"
          },
          "md5": {
            "type": "string"
          }
        }
      },
      "GearRole": {
        "type": "string",
        "enum": [
          "unspecified",
          "admin",
          "peer",
          "device"
        ]
      },
      "GearStatus": {
        "type": "string",
        "enum": [
          "unspecified",
          "active",
          "blocked"
        ]
      },
      "GearFirmwareChannel": {
        "type": "string",
        "enum": [
          "rollback",
          "stable",
          "beta",
          "testing"
        ]
      },
      "GearCertificationType": {
        "type": "string",
        "enum": [
          "license",
          "certification"
        ]
      },
      "GearCertificationAuthority": {
        "type": "string",
        "enum": [
          "unknown",
          "ccc",
          "ce",
          "fcc",
          "miit",
          "srrc",
          "rohs",
          "internal"
        ]
      },
      "GearIMEI": {
        "type": "object",
        "required": [
          "tac",
          "serial"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "tac": {
            "type": "string"
          },
          "serial": {
            "type": "string"
          }
        }
      },
      "GearLabel": {
        "type": "object",
        "required": [
          "key",
          "value"
        ],
        "properties": {
          "key": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        }
      },
      "GearCertification": {
        "type": "object",
        "required": [
          "type",
          "authority",
          "id"
        ],
        "properties": {
          "type": {
            "$ref": "#/components/schemas/GearCertificationType"
          },
          "authority": {
            "$ref": "#/components/schemas/GearCertificationAuthority"
          },
          "id": {
            "type": "string"
          },
          "authority_name": {
            "type": "string"
          }
        }
      },
      "HardwareInfo": {
        "type": "object",
        "properties": {
          "manufacturer": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "hardware_revision": {
            "type": "string"
          },
          "depot": {
            "type": "string"
          },
          "firmware_semver": {
            "type": "string"
          },
          "imeis": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GearIMEI"
            }
          },
          "labels": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GearLabel"
            }
          }
        }
      },
      "DeviceInfo": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "sn": {
            "type": "string"
          },
          "hardware": {
            "$ref": "#/components/schemas/HardwareInfo"
          }
        }
      },
      "FirmwareConfig": {
        "type": "object",
        "properties": {
          "channel": {
            "$ref": "#/components/schemas/GearFirmwareChannel"
          }
        }
      },
      "Configuration": {
        "type": "object",
        "properties": {
          "certifications": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GearCertification"
            }
          },
          "firmware": {
            "$ref": "#/components/schemas/FirmwareConfig"
          }
        }
      },
      "Registration": {
        "type": "object",
        "required": [
          "public_key",
          "role",
          "status",
          "created_at",
          "updated_at"
        ],
        "properties": {
          "public_key": {
            "type": "string"
          },
          "role": {
            "$ref": "#/components/schemas/GearRole"
          },
          "status": {
            "$ref": "#/components/schemas/GearStatus"
          },
          "auto_registered": {
            "type": "boolean"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "approved_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "RegistrationList": {
        "type": "object",
        "required": [
          "items"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Registration"
            }
          }
        }
      },
      "Runtime": {
        "type": "object",
        "required": [
          "online",
          "last_seen_at"
        ],
        "properties": {
          "online": {
            "type": "boolean"
          },
          "last_seen_at": {
            "type": "string",
            "format": "date-time"
          },
          "last_addr": {
            "type": "string"
          }
        }
      },
      "RefreshResult": {
        "type": "object",
        "required": [
          "gear"
        ],
        "properties": {
          "gear": {
            "$ref": "#/components/schemas/Gear"
          },
          "updated_fields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "Gear": {
        "type": "object",
        "required": [
          "public_key",
          "role",
          "status",
          "device",
          "configuration",
          "created_at",
          "updated_at"
        ],
        "properties": {
          "public_key": {
            "type": "string"
          },
          "role": {
            "$ref": "#/components/schemas/GearRole"
          },
          "status": {
            "$ref": "#/components/schemas/GearStatus"
          },
          "device": {
            "$ref": "#/components/schemas/DeviceInfo"
          },
          "configuration": {
            "$ref": "#/components/schemas/Configuration"
          },
          "auto_registered": {
            "type": "boolean"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "approved_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "OTASummary": {
        "type": "object",
        "required": [
          "depot",
          "channel",
          "firmware_semver",
          "files"
        ],
        "properties": {
          "depot": {
            "type": "string"
          },
          "channel": {
            "type": "string"
          },
          "firmware_semver": {
            "type": "string"
          },
          "files": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DepotFile"
            }
          }
        }
      },
      "PublicKeyResponse": {
        "type": "object",
        "required": [
          "public_key"
        ],
        "properties": {
          "public_key": {
            "type": "string"
          }
        }
      },
      "ApproveRequest": {
        "type": "object",
        "required": [
          "role"
        ],
        "properties": {
          "role": {
            "$ref": "#/components/schemas/GearRole"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "$ref": "#/components/schemas/ErrorPayload"
          }
        }
      },
      "ErrorPayload": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "details": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "RegistrationRequest": {
        "type": "object",
        "required": [
          "public_key",
          "device"
        ],
        "properties": {
          "public_key": {
            "type": "string"
          },
          "device": {
            "$ref": "#/components/schemas/DeviceInfo"
          },
          "registration_token": {
            "type": "string"
          }
        }
      },
      "RegistrationResult": {
        "type": "object",
        "required": [
          "gear",
          "registration"
        ],
        "properties": {
          "gear": {
            "$ref": "#/components/schemas/Gear"
          },
          "registration": {
            "$ref": "#/components/schemas/Registration"
          }
        }
      },
      "ServerInfo": {
        "type": "object",
        "required": [
          "public_key",
          "server_time",
          "build_commit"
        ],
        "properties": {
          "public_key": {
            "type": "string"
          },
          "server_time": {
            "type": "integer",
            "format": "int64"
          },
          "build_commit": {
            "type": "string"
          }
        }
      }
    }
  }
}
