            "schema": {
              "type": "string"
            }
          },
          {
            "name": "channel",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "./types.json#/components/schemas/GearFirmwareChannel"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Matched gears",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegistrationList"
