        "responses": {
          "200": {
            "description": "Gear registration",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./types.json#/components/schemas/Registration"
                }
              }
            }
          },
          "404": {
            "description": "Gear not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./types.json#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteGear",
        "summary": "Delete a gear",
        "tags": [
          "Resource"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/publicKey"
