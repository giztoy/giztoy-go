          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./types.json#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/gears/sn/{sn}": {
      "get": {
        "operationId": "resolveBySN",
