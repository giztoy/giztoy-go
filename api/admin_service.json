            "name": "tac",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "serial",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Resolved public key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicKeyResponse"
                }
              }
            }
          },
          "404": {
            "description": "Gear not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./types.json#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/gears/label/{key}/{value}": {
      "get": {
        "operationId": "listByLabel",
        "summary": "List gears by label",
        "tags": [
          "Query"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/cursor"
          },
          {
            "$ref": "#/components/parameters/limit"
          },
          {
            "name": "key",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "value",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Matched gears",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegistrationList"
                }
              }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./types.json#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/gears/certification/{type}/{authority}/{id}": {
      "get": {
        "operationId": "listByCertification",
        "summary": "List gears by certification",
        "tags": [
          "Query"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/cursor"
          },
          {
            "$ref": "#/components/parameters/limit"
          },
          {
            "name": "type",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "./types.json#/components/schemas/GearCertificationType"
            }
          },
          {
            "name": "authority",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "./types.json#/components/schemas/GearCertificationAuthority"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Matched gears",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegistrationList"
                }
              }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./types.json#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/gears/firmware/{depot}/{channel}": {
      "get": {
        "operationId": "listByFirmware",
