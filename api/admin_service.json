  "components": {
    "parameters": {
      "cursor": {
        "name": "cursor",
        "in": "query",
        "required": false,
        "description": "Opaque cursor returned by the previous list response",
        "schema": {
          "type": "string"
        }
      },
      "limit": {
        "name": "limit",
        "in": "query",
        "required": false,
        "description": "Maximum number of items to return. Omitted or non-positive values use the default page size; values above 200 are clamped.",
        "schema": {
          "type": "integer",
          "format": "int32",
          "default": 50
        }
      },
      "depotName": {
