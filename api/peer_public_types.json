{
  "openapi": "3.0.3",
  "info": {
    "title": "Peer Public Types",
    "description": "Schemas used by the peer public API.",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "schemas": {
      "RefreshInfo": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "manufacturer": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "hardware_revision": {
            "type": "string"
          }
        }
      },
      "RefreshIdentifiers": {
        "type": "object",
        "properties": {
          "sn": {
            "type": "string"
          },
          "imeis": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GearIMEI"
            }
          },
          "labels": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GearLabel"
            }
          }
        }
      },
      "RefreshVersion": {
        "type": "object",
        "properties": {
          "depot": {
            "type": "string"
          },
          "firmware_semver": {
            "type": "string"
          }
        }
      },
      "GearIMEI": {
        "type": "object",
        "required": [
          "tac",
          "serial"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "tac": {
            "type": "string"
          },
          "serial": {
            "type": "string"
          }
        }
      },
      "GearLabel": {
        "type": "object",
        "required": [
          "key",
          "value"
        ],
        "properties": {
          "key": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        }
      }
    }
  }
}
